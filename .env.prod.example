# ================================================================
# Variables de produccion (para el EC2 con RDS)
# Copia este archivo a .env en el servidor y rellena los valores.
# NUNCA commitear el .env real con los secretos.
# ================================================================

# --- RDS MySQL -------------------------------------------------------------
# Endpoint de tu instancia RDS (Connectivity & security en la consola).
DB_HOST=database-1.xxxxxxxxxxxx.us-east-2.rds.amazonaws.com
DB_PORT=3306

# Usuario maestro que creaste al lanzar la RDS.
DB_USER=admin

# Password del usuario maestro. Rotar si se expuso.
DB_PASSWORD=<COLOCA_AQUI_TU_PASSWORD_ROTADO>

# --- JWT -------------------------------------------------------------------
# Minimo 256 bits. Generar con: openssl rand -base64 48
JWT_SECRET=<GENERAR_UN_SECRETO_LARGO_UNICO_PARA_PROD>
JWT_EXPIRATION_MS=3600000

# --- API Gateway -----------------------------------------------------------
# Puerto expuesto al exterior. En prod suele ser 80 (detras de CloudFront/ALB).
GATEWAY_HOST_PORT=80
