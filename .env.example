# ================================================================
# Copia este archivo a .env y ajusta los valores según tu entorno.
# docker-compose lo lee automáticamente al hacer `docker compose up`.
# ================================================================

# --- JWT (OBLIGATORIO en producción) ---------------------------------------
# Secreto HMAC usado por auth-service para firmar y por product-service
# y api-gateway para verificar. Debe ser EL MISMO en los 3 servicios.
# Mínimo 256 bits (~32 caracteres ASCII). Genera uno con:
#   openssl rand -base64 48
JWT_SECRET=please-change-me-this-must-be-a-long-random-string-at-least-256-bits

# Duración del token en milisegundos. Default: 1 hora.
JWT_EXPIRATION_MS=3600000

# --- MySQL ------------------------------------------------------------------
# Password del usuario root de MySQL. En producción usa un usuario aparte
# con permisos acotados a auth_db / product_db (no root).
MYSQL_ROOT_PASSWORD=root

# Usuario que los microservicios usan para conectarse. En desarrollo = root.
MYSQL_USER=root

# Puerto expuesto en el HOST (3306 es el default de MySQL, cambia si ya tienes
# uno corriendo localmente).
MYSQL_HOST_PORT=3306

# --- API Gateway ------------------------------------------------------------
# Puerto del gateway expuesto al exterior. Los microservicios internos
# (auth 8081, product 8082) NO se exponen al host por defecto.
GATEWAY_HOST_PORT=8080
